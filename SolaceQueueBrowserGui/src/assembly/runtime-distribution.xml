<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0 
          http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>runtime-distribution</id>
    <formats>
        <format>zip</format>
        <format>tar.gz</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>SolaceQueueBrowserGui-${app.version}</baseDirectory>
    
    <fileSets>
        <!-- Include the JAR file with dependencies (renamed to use app.version) -->
        <fileSet>
            <directory>${project.build.directory}</directory>
            <outputDirectory>target</outputDirectory>
            <includes>
                <include>SolaceQueueBrowserGui-${app.version}-jar-with-dependencies.jar</include>
            </includes>
        </fileSet>
        
        <!-- Include ALL config files -->
        <fileSet>
            <directory>${project.basedir}/config</directory>
            <outputDirectory>config</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
            <excludes>
                <exclude>local-dev.json</exclude>
                <exclude>sig.txt</exclude>
            </excludes>
            <fileMode>0644</fileMode>
        </fileSet>
        
        <!-- Include runtime scripts -->
        <fileSet>
            <directory>${project.basedir}/scripts</directory>
            <outputDirectory>scripts</outputDirectory>
            <includes>
                <include>run.sh</include>
                <include>crypt-util.sh</include>
                <include>run.bat</include>
                <include>crypt-util.bat</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>
        
        <!-- Include documentation -->
        <fileSet>
            <directory>${project.basedir}/..</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>README.md</include>
            </includes>
            <filtered>false</filtered>
        </fileSet>
        
        <!-- Include docs folder (USER_GUIDE.md and images) -->
        <fileSet>
            <directory>${project.basedir}/docs</directory>
            <outputDirectory>docs</outputDirectory>
            <includes>
                <include>USER_GUIDE.md</include>
                <include>img/**</include>
            </includes>
            <filtered>false</filtered>
        </fileSet>
        
        <!-- Include img folder at root level for README.md references -->
        <fileSet>
            <directory>${project.basedir}/docs/img</directory>
            <outputDirectory>img</outputDirectory>
            <includes>
                <include>**</include>
            </includes>
            <filtered>false</filtered>
        </fileSet>
        
        <!-- Include img folder from project root -->
        <fileSet>
            <directory>${project.basedir}/../img</directory>
            <outputDirectory>img</outputDirectory>
            <includes>
                <include>**</include>
            </includes>
            <filtered>false</filtered>
        </fileSet>
        
        <!-- Include img folder from SolaceQueueBrowserGui -->
        <fileSet>
            <directory>${project.basedir}/img</directory>
            <outputDirectory>img</outputDirectory>
            <includes>
                <include>**</include>
            </includes>
            <filtered>false</filtered>
        </fileSet>
        
        <!-- Create empty directories for runtime -->
        <fileSet>
            <directory>${project.basedir}/downloads</directory>
            <outputDirectory>downloads</outputDirectory>
            <includes>
                <include>.gitkeep</include>
            </includes>
        </fileSet>
        
        <fileSet>
            <directory>${project.basedir}/logs</directory>
            <outputDirectory>logs</outputDirectory>
            <includes>
                <include>.gitkeep</include>
            </includes>
        </fileSet>
    </fileSets>
    
    <!-- Note: Only explicitly included files are packaged. 
         Source code, build artifacts, and development files are automatically excluded
         since they are not included in any fileSet above. -->
</assembly>

